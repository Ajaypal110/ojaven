GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_SECRET=

# Neon Postgres — DATABASE_URL is the pooled connection (runtime queries),
# DATABASE_URL_UNPOOLED is the direct connection (drizzle-kit push/migrate).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
CLERK_WEBHOOK_SIGNING_SECRET=

# Stealth period: /sign-up 404s until this is "true". Locally, set true so
# you can test the signup flow yourself. On Vercel (Preview/Production),
# leave false/unset until actual public launch.
ALLOW_PUBLIC_SIGNUP=false
