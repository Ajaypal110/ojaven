{
  "name": "ojaven",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @ojaven/web dev",
    "build": "pnpm --filter @ojaven/web build",
    "start": "pnpm --filter @ojaven/web start",
    "lint": "pnpm --filter @ojaven/web lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.2",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20"
  }
}
